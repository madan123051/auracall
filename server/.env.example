# AuraCall Server Configuration

# Port (default: 5000)
PORT=5000

# CORS Origin (default: http://localhost:3000)
# Comma-separated for multiple origins, or * for all
CORS_ORIGIN=http://localhost:3000

# ── TURN Server Configuration ──
# IMPORTANT: Without TURN servers, calls WILL FAIL on mobile networks
# and across different networks (firewalls, carrier NAT, etc.)
#
# Option 1: Metered.ca (recommended — free tier: 50 GB/month)
#   1. Sign up at https://www.metered.ca/stun-turn
#   2. Get your API key and app domain from the dashboard
#   3. Set both values below:
#
# METERED_API_KEY=your-api-key-here
# METERED_DOMAIN=your-app.metered.live
#
# Option 2: Custom TURN server (coturn, etc.)
#
# TURN_URL=turn:your-server.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-password
#
# Option 3: Multiple TURN servers via JSON
#
# TURN_SERVERS_JSON=[{"urls":"turn:server1.com:3478","username":"user","credential":"pass"}]

METERED_API_KEY=
METERED_DOMAIN=
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

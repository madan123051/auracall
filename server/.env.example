# AuraCall Server Configuration

# Port (default: 5000)
PORT=5000

# CORS Origin (default: http://localhost:3000)
# Comma-separated for multiple origins, or * for all
CORS_ORIGIN=http://localhost:3000

# TURN Server Configuration (optional but recommended for production)
# Without TURN, calls may fail across different networks/firewalls
# 
# Free TURN options:
# - Metered.ca (https://www.metered.ca/stun-turn) - free tier available
# - Open Relay Project (https://www.metered.ca/tools/openrelay)
#
# coturn self-hosted example:
# TURN_URL=turn:your-server.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-password
#
# Metered.ca example:
# TURN_URL=turn:a.relay.metered.ca:443
# TURN_USERNAME=your-api-key
# TURN_CREDENTIAL=your-api-secret

TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

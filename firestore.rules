rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      
      match /friends/{friendId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
      match /callHistory/{callId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    match /friendRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
    }
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Call signaling (NEW — Firestore-based calls) ──
    match /calls/{callId} {
      // Any authenticated user can read calls they're part of
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.callerUid || 
        request.auth.uid == resource.data.calleeUid
      );
      // Caller can create the call doc
      allow create: if request.auth != null && request.auth.uid == request.resource.data.callerUid;
      // Both caller and callee can update (for offer, answer, status changes)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.callerUid || 
        request.auth.uid == resource.data.calleeUid
      );
      
      // ICE candidate subcollections — caller writes callerCandidates, callee writes calleeCandidates
      match /callerCandidates/{candidateId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
      match /calleeCandidates/{candidateId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // ── Presence (NEW — Firestore heartbeat) ──
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
